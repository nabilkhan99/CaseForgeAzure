{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[3.*, 4.0.0)"
  },
  "extensions": {
    "http": {
      "routePrefix": "api",
      "cors": {
        "allowedOrigins": [
          "http://localhost:3000",
          "http://localhost:3002",
          "https://fourteenfisherman.com",
          "https://www.fourteenfisherman.com",
          "https://case-forge-frontend-n5fd.vercel.app",
          "https://case-forge-frontend-n5fd-gvwt7djho-nabil-khans-projects.vercel.app",
          "https://caseforge2025a.azurewebsites.net",
          "https://caseforge2025a.azurewebsites.net/api"
        ],
        "allowedMethods": ["GET", "POST", "OPTIONS"],
        "allowedHeaders": ["Content-Type", "Authorization"],
        "maxAge": 86400
      }
    }
  }
}
