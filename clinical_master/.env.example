# ── Gemini AI ──────────────────────────────────────────────
# Google AI Studio key (or use Vertex AI below)
GOOGLE_API_KEY=your-gemini-api-key-here

# Set to "1" to use Vertex AI instead of AI Studio
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Model for real-time voice (native audio)
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Model for text feedback generation
GEMINI_FEEDBACK_MODEL=gemini-2.5-flash

# Voice preset
DEFAULT_VOICE=Kore

# ── Session ────────────────────────────────────────────────
CONSULTATION_DURATION_SECONDS=480
READING_TIME_SECONDS=180

# ── Database (Supabase) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
