# ── Gemini AI ──────────────────────────────────────────────
# Google AI Studio key (or use Vertex AI below)
GOOGLE_API_KEY=your-gemini-api-key-here

# Set to "1" to use Vertex AI instead of AI Studio
# GOOGLE_GENAI_USE_VERTEXAI=0
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Model for real-time voice (native audio)
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Model for text feedback generation
GEMINI_FEEDBACK_MODEL=gemini-2.5-flash

# Voice preset
DEFAULT_VOICE=Kore

# ── Session ────────────────────────────────────────────────
CONSULTATION_DURATION_SECONDS=480
READING_TIME_SECONDS=180

# ── Database (Supabase) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Recording (Egress → Supabase Storage) ─────────────────
# Full consultation audio (both trainee + AI patient) recorded server-side via
# LiveKit Egress and uploaded to a private Supabase Storage bucket. Internal use.
# Leave the S3 keys blank to disable uploads even when RECORDING_ENABLED=true.
RECORDING_ENABLED=true
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=your-project-region
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
RECORDING_BUCKET=consultation-recordings
