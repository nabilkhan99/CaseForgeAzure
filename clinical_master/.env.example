# Clinical Master - Environment Variables
# Copy this to .env and fill in your API key

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://ai-caseforge2025a060083517978.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-primary-api-key-here

# Realtime API (voice) - Keep on 2024-10-01-preview until newer versions support it
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_REALTIME_API_VERSION=2024-10-01-preview

# Chat Completions API (text/feedback) - Can use newer versions
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_CHAT_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_API_KEY=your-chat-deployment-key-here

# Session Configuration
CONSULTATION_DURATION_SECONDS=120

# Voice Configuration
DEFAULT_VOICE=marin

# Turn Detection Configuration  
TURN_DETECTION_TYPE=semantic_vad
NOISE_REDUCTION_TYPE=near_field
