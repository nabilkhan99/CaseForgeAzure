# Clinical Master - Environment Variables
# Copy this to .env and fill in your values

# Azure OpenAI Configuration (shared endpoint)
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-primary-api-key-here

# Realtime API (patient voice agent)
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview
DEFAULT_VOICE=shimmer
TURN_DETECTION_TYPE=semantic_vad
NOISE_REDUCTION_TYPE=near_field

# Chat Completions API (used by feedback agent)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_CHAT_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_API_KEY=your-chat-deployment-key-here

# Session Configuration
CONSULTATION_DURATION_SECONDS=300
READING_DURATION_SECONDS=180

# Supabase Configuration
SUPABASE_URL=https://jhpjftxnftuxzzxnknbx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
